# ──────────────────────────────────────────────────────────────
# Environment variables required for this project
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# Sender.net API key
# Required for: /api/subscribe (email sign-ups), /api/nigeria-order (book delivery confirmations)
# Get yours at: https://app.sender.net > Settings > API
SENDER_API_KEY=

# Sender.net group ID for Nigeria physical book orders
# Default (if unset): bqoKx7
# Used by: /api/nigeria-order/route.ts
SENDER_GROUP_ID=bqoKx7
